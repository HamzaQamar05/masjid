+        posts: item.posts?.length ? item.posts : current.posts,
+        opportunities: item.opportunities?.length ? item.opportunities : current.opportunities
+      };
+    });
+    return [...merged, ...currentItems.filter((item) => !incomingMap.has(String(item.id)))];
+  }
