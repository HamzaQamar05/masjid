+      return {
+        ...current,
+        ...item,
+        isFollowing: item.isFollowing ?? current.isFollowing,
+        isFavorited: item.isFavorited ?? current.isFavorited,
+        notifyPrayers: item.notifyPrayers ?? current.notifyPrayers,
+        followerCount: item.followerCount ?? current.followerCount,
