# Copy this file to backend/.env locally or configure these vars in your host.
# Never commit real production secrets, database URLs, or private keys.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
FRONTEND_URL=https://mujtamaconnect.com
APP_URL=https://mujtamaconnect.com
PUBLIC_API_URL=https://api.mujtamaconnect.com
UPLOADS_DIR=./uploads
MUSLIM_SALAT_API_KEY=
CORS_ALLOWED_ORIGINS=https://mujtamaconnect.com,https://www.mujtamaconnect.com,capacitor://localhost,http://localhost
# Leave this blank in the public template. Put the real value in backend/.env
# locally or in your production host's secret environment variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Mujtama Connect <app@mujtamaconnect.com>

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PRAYER_NOTIFICATION_JOB_ENABLED=true

GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_SERVICE_ID=
IOS_BUNDLE_ID=
APPLE_PAY_MERCHANT_ID=
PAYMENT_PROCESSOR_PROVIDER=
