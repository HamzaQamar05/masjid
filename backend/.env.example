# Copy this file to backend/.env locally or configure these vars in your host.
# Never commit real production secrets, database URLs, or private keys.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
FRONTEND_URL=https://your-app.example
APP_URL=https://your-app.example
PUBLIC_API_URL=https://api.your-app.example
UPLOADS_DIR=./uploads
MUSLIM_SALAT_API_KEY=
CORS_ALLOWED_ORIGINS=https://your-app.example
# Leave this blank in the public template. Put the real value in backend/.env
# locally or in your production host's secret environment variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PRAYER_NOTIFICATION_JOB_ENABLED=true
