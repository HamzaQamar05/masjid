{
  "name": "ummah-connect-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node node_modules/prisma/build/index.js migrate deploy && node node_modules/prisma/build/index.js generate && node server.js",
    "serve": "node server.js",
    "generate": "node node_modules/prisma/build/index.js generate",
    "db:push:dev": "node node_modules/prisma/build/index.js db push",
    "migrate:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.11",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
